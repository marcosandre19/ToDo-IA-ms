{
  "info": {
    "name": "ToDo-IA-ms — Tarefas API",
    "_postman_id": "a1b2c3d4-todo-ia-ms-tarefas-collection",
    "description": "MVP de API REST de gerenciamento de tarefas (Spring Boot 2.7 / Java 11). Cobre os 5 endpoints de Tarefa e o /health do actuator, com cenários de sucesso, validação (400), recurso inexistente (404) e regressões. Ajustar a variável {{baseUrl}} conforme o ambiente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "tarefaId", "value": "1", "description": "Capturado do POST de criação no caminho feliz" }
  ],
  "item": [
    {
      "name": "0. Health",
      "item": [
        {
          "name": "GET /health — esperado 200 {status:UP}",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },

    {
      "name": "1. Caminho feliz — fluxo CRUD ponta a ponta",
      "item": [
        {
          "name": "POST minimo (so titulo) — esperado 201",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.test('header Location presente', () => pm.expect(pm.response.headers.get('Location')).to.match(/\\/api\\/tarefas\\/\\d+$/));",
                  "const body = pm.response.json();",
                  "pm.test('id populado', () => pm.expect(body.id).to.be.a('number'));",
                  "pm.test('status default PENDENTE', () => pm.expect(body.status).to.eql('PENDENTE'));",
                  "pm.test('prioridade default MEDIA', () => pm.expect(body.prioridade).to.eql('MEDIA'));",
                  "pm.collectionVariables.set('tarefaId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Comprar pao\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/tarefas", "host": ["{{baseUrl}}"], "path": ["api", "tarefas"] }
          }
        },
        {
          "name": "POST completo — esperado 201",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('campos populados pelo servidor', () => {",
                  "  pm.expect(body.id).to.be.a('number');",
                  "  pm.expect(body.criadoEm).to.match(/Z$/);",
                  "  pm.expect(body.atualizadoEm).to.match(/Z$/);",
                  "});",
                  "pm.collectionVariables.set('tarefaId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Revisar pull request #42\",\n  \"descricao\": \"Validar testes da camada de service e cobertura.\",\n  \"prioridade\": \"ALTA\",\n  \"dataVencimento\": \"2026-12-31\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/tarefas", "host": ["{{baseUrl}}"], "path": ["api", "tarefas"] }
          }
        },
        {
          "name": "GET listar tudo — esperado 200 array",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tarefas", "host": ["{{baseUrl}}"], "path": ["api", "tarefas"] }
          }
        },
        {
          "name": "GET filtro status=PENDENTE — esperado 200",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tarefas?status=PENDENTE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tarefas"],
              "query": [{ "key": "status", "value": "PENDENTE" }]
            }
          }
        },
        {
          "name": "GET filtro prioridade=ALTA — esperado 200",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tarefas?prioridade=ALTA",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tarefas"],
              "query": [{ "key": "prioridade", "value": "ALTA" }]
            }
          }
        },
        {
          "name": "GET filtros combinados — esperado 200",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tarefas?status=EM_ANDAMENTO&prioridade=ALTA",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tarefas"],
              "query": [
                { "key": "status", "value": "EM_ANDAMENTO" },
                { "key": "prioridade", "value": "ALTA" }
              ]
            }
          }
        },
        {
          "name": "GET por id — esperado 200",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tarefas/{{tarefaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tarefas", "{{tarefaId}}"]
            }
          }
        },
        {
          "name": "PUT atualiza tudo — esperado 200, criadoEm preservado",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('atualizadoEm > criadoEm', () => {",
                  "  pm.expect(new Date(body.atualizadoEm).getTime()).to.be.gte(new Date(body.criadoEm).getTime());",
                  "});",
                  "pm.test('titulo atualizado', () => pm.expect(body.titulo).to.include('atualizado'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Revisar pull request #42 (atualizado)\",\n  \"descricao\": \"Conferir tambem o changelog.\",\n  \"status\": \"EM_ANDAMENTO\",\n  \"prioridade\": \"ALTA\",\n  \"dataVencimento\": \"2026-05-12\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tarefas/{{tarefaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tarefas", "{{tarefaId}}"]
            }
          }
        },
        {
          "name": "DELETE — esperado 204 sem body",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/tarefas/{{tarefaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tarefas", "{{tarefaId}}"]
            }
          }
        }
      ]
    },

