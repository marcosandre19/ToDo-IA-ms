# Variáveis de ambiente do projeto.
#
# Copie este arquivo para `.env` e ajuste conforme o seu ambiente.
# O arquivo `.env` está no .gitignore — NUNCA versione segredos reais.
#
# As variáveis aqui são opcionais: se não definidas, o
# `application.properties` aplica defaults para H2 em modo arquivo
# (suficiente para desenvolvimento local).

# JDBC URL do banco. Para H2 em modo arquivo, manter o default abaixo.
# Para Postgres em produção, exemplo:
#   DATABASE_URL=jdbc:postgresql://localhost:5432/tarefas
DATABASE_URL=jdbc:h2:file:./data/tarefas;AUTO_SERVER=TRUE

# Usuário do banco.
DATABASE_USERNAME=sa

# Senha do banco. Vazia no H2 local; obrigatória em qualquer ambiente
# real (Postgres, MySQL, etc.).
DATABASE_PASSWORD=
